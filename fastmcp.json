{
  "$schema": "https://gofastmcp.com/public/schemas/fastmcp.json/v1.json",
  "source": {
    "type": "filesystem",
    "path": "server.py",
    "entrypoint": "mcp"
  },
  "environment": {
    "type": "uv",
    "python": ">=3.11",
    "project": "."
  },
  "deployment": {
    "transport": "streamable-http",
    "host": "127.0.0.1",
    "port": 3005,
    "path": "/mcp",
    "log_level": "INFO",
    "env": {
      "SLACK_MCP_XOXC_TOKEN": "${SLACK_MCP_XOXC_TOKEN}",
      "SLACK_MCP_XOXD_TOKEN": "${SLACK_MCP_XOXD_TOKEN}",
      "SLACK_MCP_ENABLED_TOOLS": "${SLACK_MCP_ENABLED_TOOLS}",
      "SLACK_MCP_ADD_MESSAGE_TOOL": "${SLACK_MCP_ADD_MESSAGE_TOOL}",
      "SLACK_MCP_USER_AGENT": "${SLACK_MCP_USER_AGENT}",
      "SLACK_MCP_PROXY": "${SLACK_MCP_PROXY}",
      "SLACK_MCP_CACHE_TTL": "${SLACK_MCP_CACHE_TTL}",
      "SLACK_MCP_LOG_LEVEL": "${SLACK_MCP_LOG_LEVEL}",
      "SLACK_MCP_LOG_FORMAT": "${SLACK_MCP_LOG_FORMAT}",
      "SLACK_MCP_LOG_COLOR": "${SLACK_MCP_LOG_COLOR}",
      "SLACK_MCP_API_KEY": "${SLACK_MCP_API_KEY}",
      "MCP_API_KEY": "${MCP_API_KEY}",
      "MCP_API_KEYS": "${MCP_API_KEYS}",
      "API_KEY_MODE": "${API_KEY_MODE}",
      "SLACK_MCP_BACKEND_MODE": "${SLACK_MCP_BACKEND_MODE}",
      "SLACK_MCP_BACKEND_BINARY": "${SLACK_MCP_BACKEND_BINARY}",
      "SLACK_MCP_PACKAGE_SPEC": "${SLACK_MCP_PACKAGE_SPEC}",
      "MCP_TRANSPORT": "streamable-http",
      "MCP_HOST": "127.0.0.1",
      "MCP_PORT": "3005",
      "MCP_PATH": "/mcp",
      "MCP_HEALTH_PATH": "/health",
      "FASTMCP_TRANSPORT": "streamable-http",
      "HOST": "127.0.0.1",
      "PORT": "3005"
    }
  }
}
