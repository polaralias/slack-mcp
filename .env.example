# Escape literal `$` characters as `$$` when using Docker Compose env files.

# Required Slack browser-session auth
SLACK_MCP_XOXC_TOKEN=xoxc-...
SLACK_MCP_XOXD_TOKEN=xoxd-...

# Required MCP client auth
SLACK_MCP_API_KEY=change-me

# Preserve the default read-only tool surface unless you want to customize it.
SLACK_MCP_ENABLED_TOOLS=conversations_history,conversations_replies,attachment_get_data,conversations_search_messages,conversations_unreads,channels_list,usergroups_list,users_search

# Optional generic aliases
# MCP_API_KEY=change-me
# MCP_API_KEYS=key-one,key-two

# Optional API-key mode override
# API_KEY_MODE=disabled

# Execution mode for local `python scripts/run_server.py serve` usage:
# auto = prefer local Go source, fallback to npm package
# go = require local Go source + Go toolchain
# package = always use the published npm package
# SLACK_MCP_RUN_MODE=auto

# Optional upstream Slack MCP runtime settings
# SLACK_MCP_USER_AGENT=Mozilla/5.0 ...
# SLACK_MCP_PROXY=http://127.0.0.1:8080
# SLACK_MCP_CACHE_TTL=1h

# Optional runner override. Defaults to the published package below.
# SLACK_MCP_PACKAGE_SPEC=slack-mcp-server@latest

# Optional MCP endpoint overrides
# SLACK_MCP_HOST_PORT=3005
# SLACK_MCP_PORT=3005
# SLACK_MCP_PATH=/mcp
# SLACK_MCP_HOST=127.0.0.1
# MCP_HOST=127.0.0.1
# MCP_PORT=3005
# MCP_PATH=/mcp
